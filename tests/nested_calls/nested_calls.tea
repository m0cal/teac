use std;

fn func1(x:i32, y:i32, z:i32) -> i32 {
  if z == 0 {
    return x * y;
  }
  else {
    return func1(x, y - z, 0);
  }
}

fn func2(x:i32, y:i32) -> i32 {
  if y!=0 {
    return func2(x-(x/y)*y, 0);
  }
  else {
    return x;
  }
}

fn func3(x:i32, y:i32) -> i32{
  if y == 0 {
    return x + 1;
  }
  else {
    return func3(x + y, 0);
  }
}

fn func4(x:i32, y:i32, z:i32) -> i32 {
  if x!=0 {
    return y;
  }
  else {
    return z;
  }
}

fn func5(x:i32) -> i32 {
  return 0-x;
}

fn func6(x:i32, y:i32) -> i32 {
  if (x!=0) && (y!=0) {
    return 1;
  }
  else {
    return 0;
  }
}

fn func7(x:i32) -> i32 {
  if !(x!=0) {
    return 1;
  }
  else {
    return 0;
  }
}

fn main() -> i32 {
  std::timer_start(97);
  let i1:i32 = std::getint();
  let i2:i32 = std::getint();
  let i3:i32 = std::getint();
  let i4:i32 = std::getint();
  let arr: [i32; 10];
  let i:i32 = 0;
  while i < 10 {
    arr[i] = std::getint();
    i = i + 1;
  }
  let a:i32 = func1(
      func2(
          func1(
              func3(func4(func5(func3(func2(func6(func7(i1), func5(i2)), i3),
                                      i4)),
                          arr[0],
                          func1(func2(func3(func4(func5(arr[1]),
                                                  func6(arr[2], func7(arr[3])),
                                                  func2(arr[4], func7(arr[5]))),
                                            arr[6]),
                                      arr[7]),
                                func3(arr[8], func7(arr[9])), i1)),
                    func2(i2, func3(func7(i3), i4))),
              arr[0], arr[1]),
          arr[2]),
      arr[3],
      func3(func2(func1(func2(func3(arr[4], func5(arr[5])), func5(arr[6])),
                        arr[7], func7(arr[8])),
                  func5(arr[9])),
            i1));
  std::timer_stop(117);
  return a;
}
